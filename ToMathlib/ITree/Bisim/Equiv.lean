module

public import ToMathlib.ITree.Bisim.Defs

/-! # Equivalence laws for ITree (weak) bisimulation

Reflexivity, symmetry, and transitivity of `ITree.WeakBisim`, plus the
`Setoid (ITree F α)` instance generated by it.

## Strategy

The proofs use the Tarski greatest fixed point characterization
`WeakBisim t s = ∃ R, (closure under WeakBisimF) ∧ R t s`.

* **Reflexivity**: take `R := Eq`. The closure is immediate from the
  three head cases of `Match`.

* **Symmetry**: take `R := swap WeakBisim`. The closure follows from
  `Match.swap`.

* **Transitivity**: this is the deep one. Following the Coq
  `InteractionTrees` proof of `eutt_trans` (Xia et al., POPL 2020), the
  argument needs nontrivial "up-to" infrastructure (paco companion
  closures / "gcpn" upto principles) to handle the interaction between
  τ-stripping and head alignment when the intermediate term has a
  divergent step. The supporting τ-absorption lemmas
  (`absorb_tauSteps_left`, `step_absorb_right`,
  `absorb_tauSteps_right`) are discharged here; the closing alignment
  argument that hands transitivity to the coinduction principle is
  left as a `sorry` pending the upto-principle infrastructure.

## Helpers

The τ-absorption lemmas are independently useful and are exported for
downstream proofs. They correspond to the "tau-eutt" lemmas in the
Coq library and are the workhorses of weak-bisim reasoning in the
absence of full transitivity.
-/

@[expose] public section

universe u

namespace ITree

variable {F : PFunctor.{u, u}} {α : Type u}

/-! ### `Bisim` is an equivalence -/

theorem Bisim.equivalence : Equivalence (Bisim (F := F) (α := α)) :=
  ⟨Bisim.refl', Bisim.symm', Bisim.trans'⟩

/-! ### Helper lemmas on `TauSteps` -/

namespace TauSteps

/-- If `t` has a pure head, then `TauSteps t t'` forces `t' = t`. -/
theorem rigid_of_pure {t t' : ITree F α} (r : α)
    (ht : shape' t = ⟨.pure r, PEmpty.elim⟩)
    (h : TauSteps t t') : t' = t := by
  cases h with
  | refl _ => rfl
  | step c hstep _ => exfalso; rw [ht] at hstep; cases hstep

/-- If `t` has a query head, then `TauSteps t t'` forces `t' = t`. -/
theorem rigid_of_query {t t' : ITree F α} (a : F.A) (c : F.B a → ITree F α)
    (ht : shape' t = ⟨.query a, c⟩)
    (h : TauSteps t t') : t' = t := by
  cases h with
  | refl _ => rfl
  | step c' hstep _ => exfalso; rw [ht] at hstep; cases hstep

/-- Determinism of τ-stripping on a step-headed tree: a stripping from
a step-headed tree either does nothing or proceeds through the unique
step continuation. -/
theorem step_cases {t t' : ITree F α} (c : PUnit.{u + 1} → ITree F α)
    (ht : shape' t = ⟨.step, c⟩) (h : TauSteps t t') :
    t' = t ∨ TauSteps (c PUnit.unit) t' := by
  cases h with
  | refl _ => exact Or.inl rfl
  | @step _ t'' c' ht' hr =>
      have hcc : c = c' := TauSteps.cont_eq ht ht'
      subst hcc
      exact Or.inr hr

end TauSteps

/-! ### `WeakBisim` is an equivalence -/

namespace WeakBisim

/-- Reflexivity: every tree is weakly bisimilar to itself. -/
@[refl] theorem refl (t : ITree F α) : t ≈ t := by
  refine coinduct Eq ?_ rfl
  rintro a b rfl
  rcases hsh : shape' a with ⟨sh, c⟩
  refine ⟨a, a, .refl _, .refl _, ?_⟩
  cases sh with
  | pure r =>
      refine Match.pure r ?_ ?_
      · rw [hsh]; congr 1; funext z; exact z.elim
      · rw [hsh]; congr 1; funext z; exact z.elim
  | step => exact Match.tau c c hsh hsh rfl
  | query a => exact Match.query a c c hsh hsh (fun _ => rfl)

/-- Symmetry: weak bisimilarity is symmetric. -/
@[symm] theorem symm {t s : ITree F α} (h : t ≈ s) : s ≈ t := by
  obtain ⟨R, hcl, hR⟩ := h
  refine coinduct (fun a b => R b a) ?_ hR
  intro a b hab
  obtain ⟨b', a', hb, ha, hm⟩ := hcl _ _ hab
  exact ⟨a', b', ha, hb, hm.swap⟩

/-! ### τ-absorption lemmas

These are the "tau-eutt" lemmas: τ-stripping on either side of a weak
bisimulation produces another weak bisimulation. They are independently
useful and form the building blocks for transitivity.
-/

/-- Absorbing a LHS τ-strip into a weak bisimulation. -/
theorem absorb_tauSteps_left {t t' s : ITree F α}
    (h : TauSteps t t') (hw : t' ≈ s) : t ≈ s := by
  refine coinduct (fun x y => ∃ x', TauSteps x x' ∧ x' ≈ y) ?_ ⟨t', h, hw⟩
  rintro a b ⟨a', haa', hab⟩
  obtain ⟨a'', b', ha'a'', hbb', M⟩ := hab.dest
  refine ⟨a'', b', haa'.trans ha'a'', hbb', M.mono ?_⟩
  intro x y hxy
  exact ⟨x, .refl _, hxy⟩

/-- Absorbing a single step τ-strip on the RHS of a weak bisimulation:
given `t ≈ s` and `s` step-headed with continuation `c`, conclude
`t ≈ (c .unit)`. The proof unfolds the bisim once and case-analyzes on
the head of `(c .unit)`, in the worst case unfolding the inner
`WeakBisim (ct .unit) (cs .unit)` one more level to reach a head match. -/
theorem step_absorb_right {t s : ITree F α} (c : PUnit.{u + 1} → ITree F α)
    (h : t ≈ s) (hstep : shape' s = ⟨.step, c⟩) :
    t ≈ (c PUnit.unit) := by
  refine coinduct
    (fun x z => x ≈ z ∨
      ∃ (s' : ITree F α) (c' : PUnit.{u + 1} → ITree F α),
        x ≈ s' ∧ shape' s' = ⟨.step, c'⟩ ∧ z = (c' PUnit.unit))
    ?_ (Or.inr ⟨s, c, h, hstep, rfl⟩)
  intro a b hab
  rcases hab with hab | ⟨s', c', hab, hstep', hz⟩
  · obtain ⟨a', b', ha, hb, M⟩ := hab.dest
    exact ⟨a', b', ha, hb, M.mono (fun _ _ hxy => Or.inl hxy)⟩
  subst hz
  obtain ⟨a', s₁, ha, hs, M⟩ := hab.dest
  rcases TauSteps.step_cases c' hstep' hs with hs_eq | hs_strict
  · subst hs_eq
    cases M with
    | pure _ _ hs_bad => exfalso; rw [hstep'] at hs_bad; cases hs_bad
    | query _ _ _ _ hs_bad _ => exfalso; rw [hstep'] at hs_bad; cases hs_bad
    | tau ct cs ht_a hs_a hr_weak =>
        have hcc : cs = c' := TauSteps.cont_eq hs_a hstep'
        subst hcc
        rcases hshc : shape' (cs PUnit.unit) with ⟨sh_c, c_cc⟩
        cases sh_c with
        | pure r =>
            have hshc_rw : shape' (cs PUnit.unit) =
                ⟨Shape.pure r, PEmpty.elim⟩ := by
              rw [hshc]; congr 1; funext z; exact z.elim
            obtain ⟨X, Y, hX, hY, MxY⟩ := hr_weak.dest
            have hY_eq : Y = (cs PUnit.unit) :=
              TauSteps.rigid_of_pure r hshc_rw hY
            subst hY_eq
            cases MxY with
            | pure r' ht_X hs_Y =>
                have hEq1 : (⟨Shape.pure r', PEmpty.elim⟩ :
                    (Poly F α).Obj (ITree F α)) =
                  ⟨Shape.pure r, PEmpty.elim⟩ := hs_Y.symm.trans hshc_rw
                have hrr : r' = r := Shape.pure.inj (Sigma.mk.inj hEq1).1
                subst hrr
                refine ⟨X, cs PUnit.unit,
                    ha.trans ((TauSteps.one ct ht_a).trans hX), .refl _, ?_⟩
                exact Match.pure r' ht_X hshc_rw
            | query _ _ _ _ hs_Y _ =>
                exfalso; rw [hs_Y] at hshc_rw; cases hshc_rw
            | tau _ _ _ hs_Y _ =>
                exfalso; rw [hs_Y] at hshc_rw; cases hshc_rw
        | step =>
            have hshc_rw : shape' (cs PUnit.unit) = ⟨Shape.step, c_cc⟩ := hshc
            refine ⟨a', cs PUnit.unit, ha, .refl _, ?_⟩
            refine Match.tau ct c_cc ht_a hshc_rw ?_
            exact Or.inr ⟨cs PUnit.unit, c_cc, hr_weak, hshc_rw, rfl⟩
        | query qa =>
            have hshc_rw : shape' (cs PUnit.unit) =
                ⟨Shape.query qa, c_cc⟩ := hshc
            obtain ⟨X, Y, hX, hY, MxY⟩ := hr_weak.dest
            have hY_eq : Y = (cs PUnit.unit) :=
              TauSteps.rigid_of_query qa c_cc hshc_rw hY
            subst hY_eq
            cases MxY with
            | pure _ _ hs_Y =>
                exfalso; rw [hs_Y] at hshc_rw; cases hshc_rw
            | query qa' c_X c_Y ht_X hs_Y hcc_XY =>
                have hEq : (⟨Shape.query qa', c_Y⟩ :
                    (Poly F α).Obj (ITree F α)) =
                  ⟨Shape.query qa, c_cc⟩ := hs_Y.symm.trans hshc_rw
                have hqq : qa' = qa := Shape.query.inj (Sigma.mk.inj hEq).1
                subst hqq
                have hcc : c_Y = c_cc := eq_of_heq (Sigma.mk.inj hEq).2
                subst hcc
                refine ⟨X, cs PUnit.unit,
                    ha.trans ((TauSteps.one ct ht_a).trans hX), .refl _, ?_⟩
                refine Match.query qa' c_X c_Y ht_X hshc_rw ?_
                intro b
                exact Or.inl (hcc_XY b)
            | tau _ _ _ hs_Y _ =>
                exfalso; rw [hs_Y] at hshc_rw; cases hshc_rw
  · refine ⟨a', s₁, ha, hs_strict, ?_⟩
    exact M.mono (fun _ _ hxy => Or.inl hxy)

/-- Absorbing a sequence of τ-strips on the RHS of a weak bisimulation. -/
theorem absorb_tauSteps_right {t s s' : ITree F α}
    (h : t ≈ s) (hstrip : TauSteps s s') : t ≈ s' := by
  induction hstrip generalizing t with
  | refl _ => exact h
  | @step _ _ c ht hr ih => exact ih (step_absorb_right c h ht)

/-- Transitivity of weak bisimilarity.

**Status**: pending the upto-principle infrastructure described in the
module docstring. The supporting τ-absorption lemmas above
(`absorb_tauSteps_left`, `step_absorb_right`, `absorb_tauSteps_right`)
are the building blocks; the residual difficulty is the alignment of
two `Match` witnesses through an intermediate τ-strip when the heads
genuinely misalign (e.g. one side `pure`-headed, the other deeply
divergent). Discharging this requires "up-to-WeakBisim" companion
closures in the style of Coq's `paco`, which is itself substantial
infrastructure (~hundreds of lines). -/
@[trans] theorem trans {t s u : ITree F α}
    (h₁ : t ≈ s) (h₂ : s ≈ u) : t ≈ u := by
  sorry

theorem equivalence : Equivalence (WeakBisim (F := F) (α := α)) :=
  ⟨WeakBisim.refl, fun {_ _} => WeakBisim.symm, fun {_ _ _} => WeakBisim.trans⟩

end WeakBisim

/-! ### Setoid instance generated by `WeakBisim` -/

instance instSetoid : Setoid (ITree F α) where
  r := WeakBisim
  iseqv := WeakBisim.equivalence

/-! ### `Bisim` implies `WeakBisim` -/

theorem Bisim.toWeakBisim {t s : ITree F α} (h : t ≅ s) : WeakBisim t s := by
  cases h; exact WeakBisim.refl _

end ITree
